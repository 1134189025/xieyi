generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  WORKER
}

enum OrderStatus {
  CREATING_PAYMENT
  PENDING_PAYMENT
  PAYMENT_COMPLETED
  FAILED
  EXPIRED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  displayName  String?  @map("display_name")
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdCodes    RedemptionCode[] @relation("CreatedBy")
  claimedOrders   Order[]          @relation("ClaimedBy")
  completedOrders Order[]          @relation("CompletedBy")

  @@map("users")
}

model RedemptionCode {
  id          String    @id @default(uuid())
  code        String    @unique
  batchLabel  String?   @map("batch_label")
  usedAt      DateTime? @map("used_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  archivedAt  DateTime? @map("archived_at")

  createdBy User   @relation("CreatedBy", fields: [createdById], references: [id])
  order     Order?

  @@index([code])
  @@index([createdAt])
  @@index([batchLabel, usedAt, archivedAt, createdAt])
  @@index([archivedAt])
  @@map("redemption_codes")
}

model Order {
  id                   String      @id @default(uuid())
  trackingToken        String      @unique @map("tracking_token")
  status               OrderStatus @default(PENDING_PAYMENT)
  redemptionCodeId     String?     @unique @map("redemption_code_id")
  checkoutSessionId    String?     @map("checkout_session_id")
  checkoutUrl          String?     @map("checkout_url")
  paymentMethodId      String?     @map("payment_method_id")
  setupIntentId        String?     @map("setup_intent_id")
  setupIntentClientSecret String?  @map("setup_intent_client_secret")
  pixCode              String?     @map("pix_code")
  pixQrPng             Bytes?      @map("pix_qr_png")
  pixExpiresAt         DateTime?   @map("pix_expires_at")
  pixImageUrl          String?     @map("pix_image_url")
  billingProfileJson   Json?       @map("billing_profile_json")
  encryptedSessionData String?     @map("encrypted_session_data")
  errorMessage         String?     @map("error_message")
  generationQueuedAt   DateTime?   @map("generation_queued_at")
  generationStartedAt  DateTime?   @map("generation_started_at")
  generationFinishedAt DateTime?   @map("generation_finished_at")
  generationErrorCode  String?     @map("generation_error_code")
  generationErrorStage String?      @map("generation_error_stage")
  generationErrorDetail String?     @map("generation_error_detail")
  generationErrorHttpStatus Int?    @map("generation_error_http_status")
  submittedRedemptionCode String?  @map("submitted_redemption_code")
  claimedById          String?      @map("claimed_by_id")
  claimedAt            DateTime?    @map("claimed_at")
  claimExpiresAt       DateTime?    @map("claim_expires_at")
  completedById        String?     @map("completed_by_id")
  completedAt          DateTime?   @map("completed_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  redemptionCode RedemptionCode? @relation(fields: [redemptionCodeId], references: [id])
  claimedBy      User?          @relation("ClaimedBy", fields: [claimedById], references: [id])
  completedBy    User?          @relation("CompletedBy", fields: [completedById], references: [id])

  @@index([status])
  @@index([trackingToken])
  @@index([setupIntentId])
  @@index([createdAt])
  @@index([status, generationQueuedAt, id])
  @@index([generationFinishedAt])
  @@index([claimedById])
  @@index([status, claimedById, claimExpiresAt, createdAt, id])
  @@index([status, claimExpiresAt, createdAt, id])
  @@index([completedById, completedAt])
  @@map("orders")
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
